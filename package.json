// api/_simplybook.js
// ── SimplyBook API 共用模組 ──────────────────────────────
// 所有需要呼叫 SimplyBook 的 endpoint 都 import 這個檔案

const API_ENDPOINT = "https://user-api.simplybook.asia/";
const AUTH_ENDPOINT = "https://user-api.simplybook.asia/login";
const COMPANY = "bglescape";

// Vercel Serverless 每次冷啟動 in-memory 不保證存活
// 用模組層級快取，同一個 instance 內共用（通常可撐數分鐘）
let _tokenCache = { token: null, expiresAt: 0 };

/**
 * 取得有效的 SimplyBook access token
 * 自動處理過期重取（token 有效期 1 小時，提前 5 分鐘換新）
 */
export async function getToken(apiKey) {
  const now = Date.now();
  if (_tokenCache.token && now < _tokenCache.expiresAt) {
    return _tokenCache.token;
  }

  const res = await fetch(AUTH_ENDPOINT, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      jsonrpc: "2.0",
      id: 1,
      method: "getToken",
      params: [COMPANY, apiKey],
    }),
  });

  const data = await res.json();
  if (data.error) throw new Error(`SimplyBook getToken error: ${JSON.stringify(data.error)}`);

  const token = data.result;
  // 55 分鐘後過期（保留 5 分鐘緩衝）
  _tokenCache = { token, expiresAt: now + 55 * 60 * 1000 };
  return token;
}

/**
 * 呼叫 SimplyBook JSON-RPC API
 */
export async function sbCall(method, params, token) {
  const res = await fetch(API_ENDPOINT, {
    method: "POST",
    headers: {
      "Content-Type":   "application/json",
      "X-Company-Login": COMPANY,
      "X-Token":         token,
    },
    body: JSON.stringify({ jsonrpc: "2.0", id: 1, method, params }),
  });
  const data = await res.json();
  if (data.error) throw new Error(`SimplyBook ${method} error: ${JSON.stringify(data.error)}`);
  return data.result;
}

